# ---- Clerk Auth ----
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXX
CLERK_SECRET_KEY=sk_test_XXXX

# Sign-in / sign-up routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---- Convex ----
# Get this from your Convex dashboard → Settings → URL
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ---- Convex Dashboard Environment Variable ----
# Set this in your Convex dashboard (Settings → Environment Variables), NOT here:
# CLERK_JWT_ISSUER_DOMAIN=https://verb-noun-00.clerk.accounts.dev
